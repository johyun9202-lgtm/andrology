---
import { readdirSync } from 'node:fs'
import { join } from 'node:path'
import BaseLayout from '../layouts/BaseLayout.astro'
import { siteId as currentSiteId } from '../lib/site-data.js'

// 관리자용 페이지 — 검색엔진 색인 제외(noindex), 사이트맵에서도 제외됩니다.
// 사이트 선택 옵션은 빌드 시점의 sites/ 폴더 목록에서 자동 수집합니다.
const siteIds = readdirSync(join(process.cwd(), 'sites'), { withFileTypes: true })
  .filter((entry) => entry.isDirectory())
  .map((entry) => entry.name)
  .sort()

const DEFAULT_DASHBOARD_SITE = 'aiseolab'

// 최근 작업: Cloudflare D1에 영구 저장된 Job을 GET /api/jobs 로 불러와 표시합니다.
---

<BaseLayout title="Dashboard" description="AI 콘텐츠 생성과 SEO 자동화 작업을 관리합니다." noindex={true}>
  <div class="page-title dash-head">
    <div>
      <h1>AI Writer Dashboard</h1>
      <p>AI 콘텐츠 생성과 SEO 자동화 작업을 관리합니다.</p>
    </div>
    <button type="button" class="btn dash-logout" id="logout-btn">로그아웃</button>
  </div>

  <div class="dash-tabs" role="tablist">
    <button type="button" class="dash-tab active" id="tab-btn-create">생성 작업</button>
    <button type="button" class="dash-tab" id="tab-btn-published">게시된 글</button>
    <button type="button" class="dash-tab" id="tab-btn-settings">사이트 설정</button>
    <button type="button" class="dash-tab" id="tab-btn-entities">SEO 엔티티</button>
    <button type="button" class="dash-tab" id="tab-btn-onboarding">온보딩</button>
    <button type="button" class="dash-tab" id="tab-btn-seoops">SEO 운영센터</button>
  </div>

  <div id="tab-create">
  <section class="section contact-box">
    <h2>새 아티클 생성</h2>
    <form id="draft-form" class="dash-form">
      <label>
        키워드 <span class="required">*</span>
        <input type="text" name="keyword" placeholder="예: 전립선 비대증 원인" required />
      </label>
      <label>
        제목 (선택)
        <input type="text" name="title" placeholder="비워두면 AI가 제안합니다" />
      </label>
      <label>
        사이트 선택
        <select name="site">
          {siteIds.map((id) => (
            <option value={id} selected={id === DEFAULT_DASHBOARD_SITE}>{id}</option>
          ))}
        </select>
      </label>
      <button type="submit" class="btn">AI 초안 생성</button>
    </form>
    <p id="dash-toast" class="dash-toast" hidden></p>
  </section>

  <section class="section">
    <h2>최근 작업</h2>
    <div class="dash-table-wrap">
      <table class="dash-table">
        <thead>
          <tr>
            <th>시간</th>
            <th>사이트</th>
            <th>키워드</th>
            <th>상태</th>
            <th>작업</th>
          </tr>
        </thead>
        <tbody id="jobs-body">
          <tr id="jobs-empty">
            <td colspan="5" class="dash-empty">작업 목록을 불러오는 중...</td>
          </tr>
        </tbody>
      </table>
    </div>
    <p class="dash-note">※ 작업은 D1에 영구 저장되며 새로고침해도 유지됩니다. "글 생성 실행"은 Claude API로 초안을 생성하며 최대 1~2분 걸릴 수 있습니다. 생성된 글은 초안이며, 발행 전 반드시 사람이 검토해야 합니다.</p>
  </section>
  </div>

  <section class="section" id="tab-published" hidden>
    <h2>게시된 글</h2>
    <form id="pub-filter" class="dash-pub-filter">
      <select name="site" id="pub-site">
        <option value="">전체 사이트</option>
        {siteIds.map((id) => <option value={id}>{id}</option>)}
      </select>
      <select name="status" id="pub-status">
        <option value="">전체 상태</option>
        <option value="published">게시됨</option>
        <option value="deleted">삭제됨</option>
      </select>
      <select name="deployment" id="pub-deployment">
        <option value="">전체 배포 상태</option>
        <option value="pending">배포 확인 중</option>
        <option value="deployed">사이트 게시 완료</option>
        <option value="deploy_failed">배포 확인 실패</option>
      </select>
      <input type="search" name="q" id="pub-search" placeholder="키워드·제목 검색" maxlength="100" />
      <button type="submit" class="dash-action-btn">검색</button>
    </form>
    <div class="dash-table-wrap">
      <table class="dash-table">
        <thead>
          <tr>
            <th>사이트</th>
            <th>제목</th>
            <th>키워드</th>
            <th>게시 시각</th>
            <th>상태</th>
            <th>작업</th>
          </tr>
        </thead>
        <tbody id="pub-body">
          <tr><td colspan="6" class="dash-empty">게시된 글을 불러오는 중...</td></tr>
        </tbody>
      </table>
    </div>
    <div class="dash-pub-pager">
      <button type="button" class="dash-action-btn" id="pub-prev">← 이전</button>
      <span id="pub-page-info"></span>
      <button type="button" class="dash-action-btn" id="pub-next">다음 →</button>
    </div>
    <p class="dash-note">※ 목록은 D1 게시 이력 기준입니다. "배포 확인"은 실제 URL이 열리는지 서버에서 검사합니다. 수정·삭제는 GitHub 커밋으로 반영되며, 재배포(1~2분) 후 사이트에 적용됩니다.</p>
  </section>

  <section class="section" id="tab-settings" hidden>
    <h2>사이트 설정</h2>
    <div class="dash-pub-filter">
      <label for="set-site" style="font-size: 13px; font-weight: 600; align-self: center;">사이트</label>
      <select id="set-site">
        {siteIds.map((id) => (
          <option value={id} selected={id === DEFAULT_DASHBOARD_SITE}>{id}</option>
        ))}
      </select>
      <a id="set-open-site" class="dash-action-btn" href="/" target="_blank" rel="noopener" hidden>홈페이지 열기 →</a>
      <button type="button" class="dash-action-btn" id="wizard-open">＋ 새 사이트 만들기</button>
      <button type="button" class="dash-action-btn dash-publish-btn" id="ai-gen-open">AI로 홈페이지 초안 만들기</button>
    </div>
    <p class="dash-meta" id="site-list" style="margin: 0 0 12px; font-size: 13px; color: var(--muted);">사이트 목록을 불러오는 중...</p>

    <div id="site-wizard" class="dash-preview" hidden style="max-height: none; margin-bottom: 16px;">
      <h3 style="margin-top: 0;">새 사이트 만들기 — 클라이언트 온보딩</h3>
      <div class="dash-edit-form" id="wizard-step-1">
        <p style="margin: 0; font-weight: 600; font-size: 13px;">1단계 — 기본정보</p>
        <label>병원명(사이트 이름) <span class="required">*</span><input type="text" id="wiz-name" maxlength="60" placeholder="예: 밝은 치과" /></label>
        <label>담당자<input type="text" id="wiz-manager" maxlength="30" placeholder="예: 김담당 실장" /></label>
        <label>담당자 연락처<input type="text" id="wiz-manager-phone" maxlength="30" placeholder="예: 010-1234-5678" /></label>
        <label>담당자 이메일<input type="text" id="wiz-manager-email" maxlength="80" placeholder="예: manager@example.com" /></label>
        <div class="dash-edit-actions">
          <button type="button" class="dash-action-btn" id="wiz-next-1">다음 →</button>
          <button type="button" class="dash-action-btn" id="wiz-cancel">닫기</button>
        </div>
      </div>
      <div class="dash-edit-form" id="wizard-step-2" hidden>
        <p style="margin: 0; font-weight: 600; font-size: 13px;">2단계 — 업종 · siteId</p>
        <div id="wiz-templates" role="radiogroup" aria-label="업종 선택"></div>
        <label>siteId (영문 소문자·숫자·하이픈, 2~30자) <span class="required">*</span><input type="text" id="wiz-siteid" maxlength="30" placeholder="예: bright-dental" /></label>
        <div class="dash-edit-actions">
          <button type="button" class="dash-action-btn" id="wiz-back-2">← 이전</button>
          <button type="button" class="dash-action-btn" id="wiz-next-2">다음 →</button>
        </div>
      </div>
      <div class="dash-edit-form" id="wizard-step-3" hidden>
        <p style="margin: 0; font-weight: 600; font-size: 13px;">3단계 — 운영방식 · 기존 홈페이지</p>
        <div id="wiz-modes" role="radiogroup" aria-label="운영방식 선택"></div>
        <label>기존 홈페이지 URL (있는 경우 — 이후 Import 단계에서 사용)<input type="text" id="wiz-existing-url" maxlength="300" placeholder="예: https://old-homepage.co.kr" /></label>
        <div class="dash-edit-actions">
          <button type="button" class="dash-action-btn" id="wiz-back-3">← 이전</button>
          <button type="button" class="dash-action-btn" id="wiz-next-3">다음 →</button>
        </div>
      </div>
      <div class="dash-edit-form" id="wizard-step-4" hidden>
        <p style="margin: 0; font-weight: 600; font-size: 13px;">4단계 — 전환정보 (예약·상담 채널)</p>
        <label>예약 URL<input type="text" id="wiz-reservation" maxlength="300" placeholder="예: https://booking.naver.com/..." /></label>
        <label>전화번호<input type="text" id="wiz-phone" maxlength="30" placeholder="예: 062-123-4567" /></label>
        <label>네이버지도 URL<input type="text" id="wiz-navermap" maxlength="300" placeholder="예: https://naver.me/..." /></label>
        <label>카카오채널 URL<input type="text" id="wiz-kakao" maxlength="300" placeholder="예: https://pf.kakao.com/..." /></label>
        <p class="dash-meta" style="margin: 0;">입력한 전환정보는 새 사이트의 초기 연락처·상담 채널에도 반영됩니다.</p>
        <div class="dash-edit-actions">
          <button type="button" class="dash-action-btn" id="wiz-back-4">← 이전</button>
          <button type="button" class="dash-action-btn" id="wiz-next-4">다음 →</button>
        </div>
      </div>
      <div class="dash-edit-form" id="wizard-step-5" hidden>
        <p style="margin: 0; font-weight: 600; font-size: 13px;">5단계 — 새 도메인</p>
        <label style="display: flex; gap: 8px; align-items: center; font-weight: 400; font-size: 13px;">
          <input type="checkbox" id="wiz-domain-undecided" checked /> 도메인 미정 (나중에 결정)
        </label>
        <label>새 도메인<input type="text" id="wiz-domain" maxlength="100" placeholder="예: brightclinic.co.kr" disabled /></label>
        <div class="dash-edit-actions">
          <button type="button" class="dash-action-btn" id="wiz-back-5">← 이전</button>
          <button type="button" class="dash-action-btn" id="wiz-next-5">다음 →</button>
        </div>
      </div>
      <div class="dash-edit-form" id="wizard-step-6" hidden>
        <p style="margin: 0; font-weight: 600; font-size: 13px;">6단계 — 작업 체크 · 확인 후 생성</p>
        <div id="wiz-checklist" style="display: grid; gap: 6px;"></div>
        <p id="wiz-summary" class="dash-meta" style="margin: 0;"></p>
        <div class="dash-edit-actions">
          <button type="button" class="dash-action-btn" id="wiz-back-6">← 이전</button>
          <button type="button" class="dash-action-btn dash-publish-btn" id="wiz-create">사이트 생성</button>
        </div>
      </div>
      <p id="wiz-status" class="dash-meta" hidden style="margin: 8px 0 0;"></p>
    </div>

    <div id="ai-generator" class="dash-preview" hidden style="max-height: none; margin-bottom: 16px;">
      <h3 style="margin-top: 0;">AI로 홈페이지 초안 만들기</h3>
      <p class="dash-meta" style="margin: 0 0 8px;">입력한 정보만 사용해 문구를 생성합니다. 생성 결과는 검토·수정 후 "적용"을 눌러야 저장됩니다.</p>
      <div class="dash-edit-form" id="ai-input-form">
        <label><span id="ai-l-name">업체명</span> <span class="required">*</span><input type="text" id="ai-name" maxlength="60" /></label>
        <label>지역<input type="text" id="ai-region" maxlength="50" placeholder="예: 광주광역시" /></label>
        <label><span id="ai-l-services">핵심 서비스/전문 분야 (콤마 구분)</span><input type="text" id="ai-services" maxlength="300" /></label>
        <label><span id="ai-l-audience">주요 고객</span><input type="text" id="ai-audience" maxlength="200" /></label>
        <label><span id="ai-l-features">업체의 특징</span><textarea id="ai-features" maxlength="300" style="min-height: 60px; white-space: normal; font-family: inherit;"></textarea></label>
        <label>원하는 분위기<input type="text" id="ai-tone" maxlength="100" placeholder="예: 신뢰감 있고 차분한" /></label>
        <label>전화번호 (비우면 기존 값 유지)<input type="text" id="ai-phone" maxlength="30" /></label>
        <label>주소 (비우면 기존 값 유지)<input type="text" id="ai-address" maxlength="120" /></label>
        <label>상담/예약 URL (비우면 기존 값 유지)<input type="url" id="ai-consult" maxlength="300" /></label>
        <label>추가 전달사항<textarea id="ai-notes" maxlength="500" style="min-height: 50px; white-space: normal; font-family: inherit;"></textarea></label>
        <div class="dash-edit-actions">
          <button type="button" class="dash-action-btn dash-publish-btn" id="ai-generate">AI 초안 생성</button>
          <button type="button" class="dash-action-btn" id="ai-close">닫기</button>
        </div>
      </div>
      <p id="ai-status" class="dash-meta" hidden style="margin: 8px 0 0;"></p>
      <div id="ai-review" hidden style="margin-top: 12px;"></div>
    </div>

    <form id="settings-form" class="dash-edit-form" style="max-width: 640px;">
      <h3 style="margin: 12px 0 0;">기본 정보</h3>
      <label>병원명(사이트명) <span class="required">*</span><input type="text" id="set-name" maxlength="60" required /></label>
      <label>병원 유형 (예: 비뇨의학과, 성형외과)<input type="text" id="set-hospitalType" maxlength="30" /></label>
      <label>지역 (예: 광주광역시)<input type="text" id="set-region" maxlength="50" /></label>
      <label>주소<input type="text" id="set-address" maxlength="120" /></label>
      <label>전화번호<input type="text" id="set-phone" maxlength="30" /></label>
      <label>병원 소개 <span class="required">*</span><textarea id="set-description" maxlength="500" style="min-height: 70px; white-space: normal; font-family: inherit;"></textarea></label>

      <h3 style="margin: 12px 0 0;">대표 문구 (Hero)</h3>
      <label>대표 문구 <span class="required">*</span><input type="text" id="set-heroTitle" maxlength="80" required /></label>
      <label>보조 문구<input type="text" id="set-heroSubtitle" maxlength="160" /></label>

      <h3 style="margin: 12px 0 0;">대표원장</h3>
      <label>이름<input type="text" id="set-doctorName" maxlength="30" /></label>
      <label>직함 (기본: 대표원장)<input type="text" id="set-doctorTitle" maxlength="30" /></label>
      <label>소개<textarea id="set-doctorBio" maxlength="500" style="min-height: 60px; white-space: normal; font-family: inherit;"></textarea></label>

      <h3 style="margin: 12px 0 0;">운영시간</h3>
      <label>평일<input type="text" id="set-hoursWeekday" maxlength="60" placeholder="예: 09:00 - 18:00" /></label>
      <label>토요일<input type="text" id="set-hoursSaturday" maxlength="60" /></label>
      <label>일요일·공휴일<input type="text" id="set-hoursSunday" maxlength="60" placeholder="예: 휴진" /></label>

      <h3 style="margin: 12px 0 0;">주요 진료 분야 (1~10개)</h3>
      <div id="set-services"></div>
      <button type="button" class="dash-action-btn" id="set-add-service">+ 분야 추가</button>

      <h3 style="margin: 12px 0 0;">상담·링크 (http/https 주소만)</h3>
      <label>상담 URL<input type="url" id="set-consultUrl" maxlength="300" /></label>
      <label>카카오 URL<input type="url" id="set-kakaoUrl" maxlength="300" /></label>
      <label>네이버 예약 URL<input type="url" id="set-naverBookingUrl" maxlength="300" /></label>
      <label>네이버 지도 URL<input type="url" id="set-naverMapUrl" maxlength="300" /></label>

      <h3 style="margin: 12px 0 0;">SEO</h3>
      <label>SEO 제목 (비우면 병원명·지역·유형으로 자동 구성)<input type="text" id="set-seoTitle" maxlength="70" /></label>
      <label>SEO 설명<textarea id="set-seoDescription" maxlength="200" style="min-height: 50px; white-space: normal; font-family: inherit;"></textarea></label>
      <label>SEO 키워드 (콤마로 구분, 최대 10개)<input type="text" id="set-seoKeywords" maxlength="300" /></label>

      <h3 style="margin: 12px 0 0;">이미지 (URL 방식)</h3>
      <label>로고 이미지 URL<input type="url" id="set-logoImage" maxlength="300" /></label>
      <label>대표(Hero) 이미지 URL<input type="url" id="set-heroImage" maxlength="300" /></label>
      <label>원장 이미지 URL<input type="url" id="set-doctorImage" maxlength="300" /></label>

      <div class="dash-edit-actions" style="margin-top: 12px;">
        <button type="submit" class="dash-action-btn dash-publish-btn" id="set-save">설정 저장</button>
      </div>
      <p id="set-status" class="dash-meta" hidden></p>
    </form>
    <p class="dash-note">※ 저장하면 GitHub에 설정 커밋이 생성되고, Cloudflare 재배포(1~2분) 후 실제 홈페이지에 반영됩니다. 아티클·메뉴 등 이 폼에 없는 설정은 그대로 보존됩니다.</p>
  </section>

  <section class="section" id="tab-entities" hidden>
    <h2>SEO 엔티티 — 진료과 · 의료진</h2>
    <p class="dash-meta" style="margin: 0 0 12px;">운영자가 입력한 실제 정보만 페이지와 구조화 데이터에 반영됩니다. 검색엔진이 병원·진료과·의료진 관계를 이해할 수 있는 기반을 만드는 내부 SEO 운영 도구입니다.</p>
    <div class="dash-pub-filter">
      <label for="ent-site" style="font-size: 13px; font-weight: 600; align-self: center;">사이트</label>
      <select id="ent-site">
        {siteIds.map((id) => (
          <option value={id} selected={id === DEFAULT_DASHBOARD_SITE}>{id}</option>
        ))}
      </select>
      <button type="button" class="dash-action-btn" id="ent-add-dept">＋ 진료과 추가</button>
      <button type="button" class="dash-action-btn" id="ent-add-doc">＋ 의료진 추가</button>
      <button type="button" class="dash-action-btn dash-publish-btn" id="ent-save">전체 저장</button>
    </div>
    <p id="ent-status" class="dash-meta" hidden style="margin: 0 0 12px;"></p>
    <h3 style="margin: 12px 0 8px;">진료과</h3>
    <div id="ent-dept-list" class="article-list"></div>
    <h3 style="margin: 16px 0 8px;">의료진</h3>
    <div id="ent-doc-list" class="article-list"></div>
    <div id="ent-editor" hidden style="margin-top: 16px;"></div>
