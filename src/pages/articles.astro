---
import BaseLayout from '../layouts/BaseLayout.astro'
import PageTitle from '../components/PageTitle.astro'
import { siteData as hospital } from '../lib/site-data.js'
---

<BaseLayout title="아티클" description={`${hospital.name} 아티클`}>
  <PageTitle title="아티클" />
  <div class="article-list">
    {
      hospital.articles.map((article) => (
        <a href={`/articles/${article.slug}/`} class="article-item-link">
          <article class="article-item">
            <h3>{article.title}</h3>
            <p>{article.summary}</p>
            <p class="meta">{article.date}</p>
          </article>
        </a>
      ))
    }
  </div>
</BaseLayout>
