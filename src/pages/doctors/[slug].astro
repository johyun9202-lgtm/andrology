---
// 의료진 상세 페이지 (Phase 13) — 실제 입력된 정보만 렌더링합니다.
// 경력·학력·자격은 운영자가 입력한 항목만 표시하며 임의로 생성하지 않습니다.
import BaseLayout from '../../layouts/BaseLayout.astro'
import { siteData as hospital } from '../../lib/site-data.js'
import { site } from '../../config/site.js'
import { isReal, isValidHttpUrl } from '../../lib/schema.js'
import {
  buildBreadcrumbSchema,
  buildPersonSchema,
  entityArrays,
} from '../../lib/schema/entity-schema.js'

export function getStaticPaths() {
  const { doctors } = entityArrays(hospital)
  return doctors.map((doctor) => ({ params: { slug: doctor.id }, props: { doctor } }))
}

const { doctor } = Astro.props
const { departments, doctors } = entityArrays(hospital)

const myDepartments = departments.filter((d) => (doctor.departmentIds ?? []).includes(d.id))
const colleagues = doctors.filter((d) => d.id !== doctor.id).slice(0, 6)
const consultUrl = isValidHttpUrl(doctor.consultationUrl) ? doctor.consultationUrl.trim() : null
const listOf = (v) => (Array.isArray(v) ? v.filter((item) => isReal(item)) : [])
const career = listOf(doctor.career)
const education = listOf(doctor.education)
const certifications = listOf(doctor.certifications)
const specialties = listOf(doctor.specialties)

const seo = doctor.seo ?? {}
const displayTitle = isReal(doctor.title) ? doctor.title : ''
const pageTitle = (typeof seo.title === 'string' && seo.title.trim()) || `${doctor.name} ${displayTitle}`.trim()
const pageDescription =
  (typeof seo.description === 'string' && seo.description.trim()) ||
  (isReal(doctor.bio) ? doctor.bio.slice(0, 150) : `${hospital.name} ${doctor.name} ${displayTitle} 소개`.trim())
const keywords = Array.isArray(seo.keywords) ? seo.keywords : []
const doctorImage = isValidHttpUrl(doctor.image) ? doctor.image.trim() : null
const imageAlt = isReal(doctor.imageAlt) ? doctor.imageAlt : `${doctor.name} ${displayTitle || '의료진'} 사진`

const schemas = [
  buildPersonSchema(doctor, hospital, site.siteUrl),
  buildBreadcrumbSchema(site.siteUrl, [
    { name: '홈', path: '/' },
    { name: '의료진 소개', path: '/doctors/' },
    { name: doctor.name, path: `/doctors/${doctor.id}/` },
  ]),
]
---

<BaseLayout title={pageTitle} description={pageDescription} jsonLd={schemas} keywords={keywords} ogImage={doctorImage ?? undefined}>
  <nav aria-label="breadcrumb" style="font-size: 13px; color: var(--muted); margin: 16px 0 0;">
    <a href="/">홈</a> › <a href="/doctors/">의료진 소개</a> › {doctor.name}
  </nav>

  <div class="page-title" style="display: flex; gap: 20px; align-items: center;">
    {doctorImage ? (
      <img src={doctorImage} alt={imageAlt} loading="lazy" style="width: 120px; height: 120px; object-fit: cover; border-radius: 16px; flex-shrink: 0;" />
    ) : (
      <div aria-hidden="true" style="width: 120px; height: 120px; border-radius: 16px; flex-shrink: 0; background: var(--accent-bg, #eff6ff); color: var(--accent); display: flex; align-items: center; justify-content: center; font-size: 40px; font-weight: 700;">{doctor.name.slice(0, 1)}</div>
    )}
    <div>
      <h1 style="margin: 0 0 6px;">{doctor.name}</h1>
      {displayTitle && <p style="margin: 0 0 6px;">{displayTitle}</p>}
      {myDepartments.length > 0 && (
        <p style="margin: 0; font-size: 14px;">
          {myDepartments.map((d, index) => (
            <>
              {index > 0 && ' · '}
              <a href={`/departments/${d.id}/`}>{d.name}</a>
            </>
          ))}
        </p>
      )}
    </div>
  </div>

  {specialties.length > 0 && (
    <section class="section">
      <h2>전문 분야</h2>
      <p>{specialties.join(' · ')}</p>
    </section>
  )}

  {isReal(doctor.bio) && (
    <section class="section">
      <h2>소개</h2>
      <p style="white-space: pre-line;">{doctor.bio}</p>
    </section>
  )}

  {career.length > 0 && (
    <section class="section">
      <h2>경력</h2>
      <ul>{career.map((item) => <li>{item}</li>)}</ul>
    </section>
  )}

  {education.length > 0 && (
    <section class="section">
      <h2>학력</h2>
      <ul>{education.map((item) => <li>{item}</li>)}</ul>
    </section>
  )}

  {certifications.length > 0 && (
    <section class="section">
      <h2>자격</h2>
      <ul>{certifications.map((item) => <li>{item}</li>)}</ul>
    </section>
  )}

  {consultUrl && (
    <section class="section">
      <div class="channel-buttons" style="margin: 0;">
        <a href={consultUrl} target="_blank" rel="noopener" class="channel-btn primary">상담 신청 →</a>
      </div>
    </section>
  )}

  {colleagues.length > 0 && (
    <section class="section">
      <h2>다른 의료진 보기</h2>
      <p>
        {colleagues.map((d, index) => (
          <>
            {index > 0 && ' · '}
            <a href={`/doctors/${d.id}/`}>{d.name}{isReal(d.title) ? ` ${d.title}` : ''}</a>
          </>
        ))}
      </p>
    </section>
  )}
</BaseLayout>
