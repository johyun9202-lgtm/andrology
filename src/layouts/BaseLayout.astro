---
import { site } from '../config/site.js'
import { siteData as hospital } from '../lib/site-data.js'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import { isValidColor } from '../lib/schema.js'
import { generateSiteSchema } from '../lib/schema/generate-schema.js'
import '../styles/global.css'

// title: 섹션명만 넘기면 "병원명 | 섹션명" 형태로 자동 생성됩니다.
// ogType: 기본 'website', 아티클 상세 페이지는 'article'을 전달합니다.
// jsonLd: 페이지별 추가 구조화 데이터(예: FAQPage)를 전달하면 함께 출력됩니다.
const { title, description = hospital.description, ogType = 'website', jsonLd } = Astro.props
const pageTitle = title ? `${hospital.name} | ${title}` : hospital.name
const canonical = new URL(Astro.url.pathname, site.siteUrl)

// 사이트 대표 구조화 데이터 — 모든 페이지에 공통 출력
// (@type은 사이트 데이터의 schema.type이 결정, 미정 값은 자동 제외)
const clinicSchema = generateSiteSchema(hospital, site.siteUrl)

// 페이지별 추가 구조화 데이터 (단일 객체/배열 모두 허용)
const extraSchemas = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : []

// 대표 색상: theme.primary가 유효한 색상 형식(#RGB/#RRGGBB)일 때만
// CSS 변수 --accent를 덮어씁니다. 없거나 잘못된 값이면 기본색이 유지됩니다.
const primaryColor = isValidColor(hospital.theme?.primary) ? hospital.theme.primary.trim() : null
---

<!doctype html>
<html lang="ko" style={primaryColor ? `--accent: ${primaryColor};` : undefined}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={hospital.name} />
    <meta property="og:locale" content="ko_KR" />

    <!-- 구조화 데이터 (JSON-LD) -->
    <script type="application/ld+json" set:html={JSON.stringify(clinicSchema)} />
    {extraSchemas.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
